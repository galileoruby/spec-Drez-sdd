# ============================================================
# Supabase Postgres - Connection strings
# ============================================================
# IMPORTANTE: Supabase entrega dos URLs distintas. Cada una tiene un uso
# específico y NO son intercambiables.
#
# 1) DATABASE_URL -> runtime de la app (FastAPI)
#    Usa el TRANSACTION POOLER (puerto 6543). Como corre sobre PgBouncer
#    en modo transaction, los prepared statements de asyncpg DEBEN
#    desactivarse en el engine (ver app/database.py).
#
# 2) DATABASE_URL_DIRECT -> Alembic migrations (NUNCA runtime)
#    Usa la DIRECT CONNECTION (puerto 5432). Alembic necesita conexión
#    directa para transacciones largas y DDL.
#
# Formato obligatorio para asyncpg:
#   postgresql+asyncpg://postgres.<project-ref>:<password>@<host>:<port>/postgres
# ============================================================

# Runtime app (transaction pooler, puerto 6543)
DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxxxxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Alembic (direct connection, puerto 5432)
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres.xxxxxxxxxxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ============================================================
# App settings
# ============================================================
APP_ENV=development
LOG_LEVEL=INFO